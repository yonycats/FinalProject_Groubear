<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/fmt" prefix="fmt"%>
<div class="app-main flex-column flex-row-fluid" id="kt_app_main">
	<div class="d-flex flex-column flex-column-fluid">
		<div id="kt_app_content" class="app-content flex-column-fluid">
			<div id="kt_app_content_container" class="app-container container-fluid">
				
					
					<div class="d-flex flex-column flex-lg-row">
						<!--begin::Sidebar-->
						<div class="flex-column flex-lg-row-auto w-100 w-lg-500px w-xl-500px mb-10 mb-lg-0">
							<!--begin::Contacts-->
							<div class="card card-flush">
								<!--end::Card header-->
								<!--begin::Card body-->
								<div class="card-body pt-5" id="kt_chat_contacts_body">
									<!--begin::List-->
									<div class="scroll-y me-n5 pe-5 h-200px h-lg-auto" data-kt-scroll="true" data-kt-scroll-activate="{default: false, lg: true}" data-kt-scroll-max-height="auto" data-kt-scroll-dependencies="#kt_header, #kt_app_header, #kt_toolbar, #kt_app_toolbar, #kt_footer, #kt_app_footer, #kt_chat_contacts_header" data-kt-scroll-wrappers="#kt_content, #kt_app_content, #kt_chat_contacts_body" data-kt-scroll-offset="5px">
										
										<!--begin::User-->
										<div class="d-flex flex-stack py-4">
											<!--begin::Details-->
											<div class="d-flex align-items-center">
												<!--begin::Details-->
												<div class="ms-5">
													<h2>공간 대여</h2>
												</div>
												<!--end::Details-->
											</div>
											<!--end::Lat seen-->
										</div>
										<!--end::User-->
										<!--begin::Separator-->
										<div class="separator separator-dashed d-none"></div>
										<!--end::Separator-->
										
										
										<!-- 회의실 이미지 -->
										<!--begin::User-->
										<div class="d-flex flex-stack py-4">
											<!--begin::Details-->
											<div class="d-flex align-items-center">
												<!--begin::Details-->
												<div class="ms-5">
													<img alt="" src="" style="width: 400px; height: 400px;">
												</div>
												<!--end::Details-->
											</div>
											<!--end::Details-->
										</div>
										<!--end::User-->
										<!--begin::Separator-->
										<div class="separator separator-dashed d-none"></div>
										<!--end::Separator-->
										
										
										
										<!--begin::User-->
										<div class="d-flex flex-stack py-4">
											<!--begin::Details-->
											<div class="d-flex align-items-center">
											
												<!--begin::Details-->
												<div class="ms-5">
													<h2>예약 현황</h2>
												</div>
												<!--end::Details-->
											</div>
											<!--end::Details-->
										</div>
										<!--end::User-->
										<!--begin::Separator-->
										<div class="separator separator-dashed d-none"></div>
										<!--end::Separator-->

										<!-- 캘린더 -->
										<!--begin::User-->
										<div class="d-flex flex-stack py-4">
											<!--begin::Details-->
											<div class="d-flex align-items-center">
												<!--begin::Details-->
												<div class="ms-5">
													<img alt="" src="" style="width: 400px; height: 400px;">
												</div>
												<!--end::Details-->
											</div>
											<!--end::Details-->
										</div>
										<!--end::User-->
										<!--begin::Separator-->
										<div class="separator separator-dashed d-none"></div>
										<!--end::Separator-->
										
										
									</div>
									<!--end::List-->
								</div>
								<!--end::Card body-->
							</div>
							<!--end::Contacts-->
						</div>
						<!--end::Sidebar-->
						
						
						
						
						<!--begin::Content-->
						<div class="flex-lg-row-fluid ms-lg-7 ms-xl-10">
							<!--begin::Messenger-->
							<div class="card" id="kt_chat_messenger">
								<!--begin::Card header-->
								
								<!--end::Card header-->
								<!--begin::Card body-->
								<div class="card-body"  id="kt_chat_messenger_body">
									
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">위치</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<span class="fw-bold fs-6 text-gray-800">3F</span>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">시설명</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<span class="fw-bold fs-6 text-gray-800">3F 커뮤니티 룸</span>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">이용 시간 </label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<span class="fw-bold fs-6 text-gray-800">(평일) 9:00 ~ 18:00</span>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">최대 인원수</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<span class="fw-bold fs-6 text-gray-800">8명</span>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">시설 안내</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<span class="fw-bold fs-6 text-gray-800">퇴실 시간 엄수 / 정리 정돈 필수  / 음식물 섭취 불가/ 비품 망실/파손시 배상</span>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">비품</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<span class="fw-bold fs-6 text-gray-800">의자, 책상, 프로젝터, 화이트보드, 스크린, 소화기</span>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">예약자명</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<input id="myInput" name="searchWord" type="text" data-kt-ecommerce-product-filter="search" class="form-control form-control-solid w-400px ps-12" style="margin-top: 0.5em;" placeholder="연락처" value="${searchWord }"/>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">연락처</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												    <input id="myInput" name="searchWord" type="text" data-kt-ecommerce-product-filter="search" class="form-control form-control-solid w-400px ps-12" style="margin-top: 0.5em;" placeholder="연락처" value="${searchWord }"/>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">예약일자</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<input id="myInput" name="searchWord" type="text" data-kt-ecommerce-product-filter="search" class="form-control form-control-solid w-400px ps-12" style="margin-top: 0.5em;" placeholder="연락처" value="${searchWord }"/>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
									<!--begin::Row-->
										<div class="row mb-7">
											<!--begin::Label-->
											<label class="col-lg-4 fw-semibold text-muted">예약 시간</label>
											<!--end::Label-->
											<!--begin::Col-->
											<div class="col-lg-8">
												<div class="row mt-5 mb-5">
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 <input type="button" class="form-control" name="year1" value="11:00" style="width: 15%;" />
												 </div>
											</div>
											<!--end::Col-->
										</div>
										<!--end::Row-->
								
								</div>
								<!--end::Card body-->
							</div>
							<!--end::Messenger-->
						</div>
						<!--end::Content-->
					</div>
					<!--end::Layout-->
				</div>
			</div>
		</div>
	</div>
